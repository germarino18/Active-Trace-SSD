# activia-trace — Configuración base
# Copiar a .env y completar con valores reales

# Conexión a PostgreSQL (asyncpg)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/activia_trace

# Base de datos de test
DATABASE_URL_TEST=postgresql+asyncpg://postgres:postgres@localhost:5433/activia_trace_test

# Firma JWT — mínimo 32 caracteres
SECRET_KEY=changeme-minimo-32-caracteres-seguro

# Cifrado AES-256 para PII — exactamente 32 caracteres
ENCRYPTION_KEY=changeme-exactly-32-chars-long!

# Expiración del access token en minutos (default: 15)
ACCESS_TOKEN_EXPIRE_MINUTES=15
